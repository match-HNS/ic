public StartVoteRules() {
	g_flTimeToVoteMode = get_gametime() + 20.0;
	arrayset(iVoteRules, 0, sizeof(iVoteRules));
	arrayset(g_bVotedRules, false, sizeof(g_bVotedRules));

	new iPlayers[MAX_PLAYERS], iNum;
	get_players(iPlayers, iNum, "ch");
	for (new i; i < iNum; i++) {
		new id = iPlayers[i];
		if (!is_user_connected(id))
			continue;
		if (getUserTeam(id) != TEAM_CT && getUserTeam(id) != TEAM_TERRORIST)
			continue;

		new szMsg[64];
		formatex(szMsg, charsmax(szMsg), "\r投票: 游戏模式");
		new hMenu = menu_create(szMsg, "HandlerStartVoteRules");

		menu_additem(hMenu, "\wMR (最大回合数)", "1");
		menu_additem(hMenu, "\w计时模式", "2");
		menu_additem(hMenu, "\w决斗模式 (1v1)", "3");
		menu_additem(hMenu, "\w点位积分模式", "4");
		menu_additem(hMenu, "\w点位扣除模式", "5");
		menu_additem(hMenu, "\w回合制比赛", "6");

		menu_setprop(hMenu, MPROP_EXIT, MEXIT_ALL);
		menu_display(id, hMenu, 0);
	}

	set_task(20.0, "VoteFinished", 83129);
}

public HandlerStartVoteRules(id, hMenu, item) {
	if (item == MENU_EXIT || get_gametime() > g_flTimeToVoteMode) {
		menu_destroy(hMenu);
		return;
	}

	if (g_bVotedRules[id]) {
		menu_destroy(hMenu);
		return;
	}
	g_bVotedRules[id] = true;

	new szData[6], szName[64], iAccess, iCallback;
	menu_item_getinfo(hMenu, item, iAccess, szData, charsmax(szData), szName, charsmax(szName), iCallback);
	menu_destroy(hMenu);

	new key = str_to_num(szData) - 1; // 1-based → 0-based

	new szRuleNames[NATCH_RULES][32] = {
		"MR",
		"Timer",
		"Duel",
		"PointScap",
		"Vampire",
		"Rounds"
	};

	if (key >= 0 && key < sizeof(iVoteRules)) {
		iVoteRules[key]++;
		chat_print(0, "^3%n^1 voted for ^3%s^1.", id, szRuleNames[key]);
	}
}

public VoteFinished() {
	new iMaxVotes = -1;
	new iWinners[5], iWinnerCount = 0;

	for (new i = 0; i < sizeof(iVoteRules); i++) {
		if (iVoteRules[i] > iMaxVotes) {
			iMaxVotes = iVoteRules[i];
			iWinnerCount = 0;
			iWinners[iWinnerCount++] = i;
		} else if (iVoteRules[i] == iMaxVotes && iMaxVotes > 0) {
			iWinners[iWinnerCount++] = i;
		}
	}

	if (iWinnerCount == 0) {
		g_iCurrentRules = NATCH_RULES:random_num(0, sizeof(iVoteRules) - 1);
	} else {
		g_iCurrentRules = NATCH_RULES:iWinners[random(iWinnerCount)];
	}

	new szRuleNames[NATCH_RULES][32] = {
		"MR",
		"Timer",
		"Duel",
		"PointScap",
		"Vampire",
		"Rounds"
	};

	chat_print(0, "^3%s^1 won the vote! Mode set to ^3%s^1.",
		szRuleNames[g_iCurrentRules],
		szRuleNames[g_iCurrentRules]);

	// ★ v5.7: 保存模式 → 显示地图选择菜单
	// 在地图选择完成后，由 mapPick 系统自动启动比赛
	savePendingMode(g_iCurrentRules);

	// 显示地图选择菜单给所有玩家
	new iPlayers[MAX_PLAYERS], iNum;
	get_players(iPlayers, iNum, "ch");
	for (new i; i < iNum; i++) {
		new id = iPlayers[i];
		if (is_user_connected(id) && (getUserTeam(id) == TEAM_CT || getUserTeam(id) == TEAM_TERRORIST)) {
			showMapPickMenu(id);
		}
	}

	arrayset(iVoteRules, 0, sizeof(iVoteRules));
}

